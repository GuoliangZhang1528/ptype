# ===========================================
# PType 环境变量配置
# ===========================================

# -------------------------------------------
# 数据库配置（Docker Compose 使用）
# -------------------------------------------
DB_USER=ptype
DB_PASSWORD=ptype
DB_NAME=ptype
DB_PORT=5432

# DATABASE_URL 由 Docker Compose 自动构建
# 本地开发时可手动设置：
# DATABASE_URL="postgresql://ptype:ptype@localhost:5432/ptype?schema=public"

# -------------------------------------------
# 安全密钥（必须修改！）
# -------------------------------------------

# JWT 密钥（用于用户认证）
# 请使用强随机字符串，至少 32 个字符
# 可以使用 openssl rand -base64 32 生成
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# 签名密钥（用于请求签名验证，防止 API 滥用）
# 请使用强随机字符串，至少 32 个字符
SIGNATURE_SECRET="your-signature-secret-key-change-this-in-production"

# -------------------------------------------
# Cookie 安全设置
# -------------------------------------------
# - true: 仅通过 HTTPS 传输 Cookie（适用于 HTTPS 环境，推荐）
# - false: 允许通过 HTTP 传输 Cookie（适用于无 SSL 的 HTTP 环境）
# ⚠️ 如果你的服务器没有 HTTPS，必须设置为 false，否则登录后无法保持会话
SECURE_COOKIES=false

# -------------------------------------------
# 应用部署配置
# -------------------------------------------

# 项目根目录路径（用于部署在子路径下）
# 例如：/ptype/ 或 /app/ 或 /
# 默认为 / （根路径）
NEXT_PUBLIC_BASE_PATH=/

# -------------------------------------------
# 可选配置
# -------------------------------------------

# Node 环境（production / development）
# NODE_ENV=production

# 服务端口（默认 3000）
# PORT=3000

# Socket.IO 对战服务端口（默认 4000）
# SOCKET_PORT=4000

# Socket.IO CORS 来源。生产环境建议设置为你的站点 URL，例如 https://example.com
# SOCKET_CORS_ORIGIN="*"
